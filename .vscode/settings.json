{
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "accessibility.signalOptions": {
        "volume": 70,
        "debouncePositionChanges": false,
        "experimental.delays": {
            "general": {
                "announcement": 3000,
                "sound": 400
            },
            "warningAtPosition": {
                "announcement": 3000,
                "sound": 1000
            },
            "errorAtPosition": {
                "announcement": 3000,
                "sound": 1000
            }
        }
    }
}